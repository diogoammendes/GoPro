{
  "name": "gopro-media-downloader",
  "version": "1.0.0",
  "description": "Self-hosted GoPro media downloader with cloud upload support",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm start",
    "build": "cd client && npm run build",
    "setup": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "better-sqlite3": "^9.4.3",
    "axios": "^1.6.7",
    "tough-cookie": "^4.1.3",
    "axios-cookiejar-support": "^5.0.3",
    "multer": "^1.4.5-lts.1",
    "googleapis": "^133.0.0",
    "webdav": "^5.6.0",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
